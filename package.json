{
  "name": "irpf-parser-platform",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "scripts": {
    "dev": "npm run dev --workspace apps/web",
    "build": "npm run build --workspace apps/web",
    "start": "npm run start --workspace apps/web",
    "lint": "npm run lint --workspace apps/web",
    "typecheck": "npm run typecheck --workspace apps/web && npm run typecheck --workspace packages/contracts && npm run typecheck --workspace packages/rules",
    "test:e2e": "npm run test:e2e --workspace apps/web",
    "prototype:reset": "node scripts/reset-presentation-prototype.mjs --env-file .vercel/.env.presentation",
    "eval": "python3 evaluation/scripts/run_eval.py"
  }
}
