# Railway n8n runtime
N8N_ENCRYPTION_KEY=
N8N_HOST=0.0.0.0
N8N_PORT=5678
N8N_PROTOCOL=https
N8N_PROXY_HOPS=1
N8N_BLOCK_ENV_ACCESS_IN_NODE=false
N8N_LOG_LEVEL=info

# Persistent DB (Railway Postgres)
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=
DB_POSTGRESDB_USER=
DB_POSTGRESDB_PASSWORD=
DB_POSTGRESDB_SCHEMA=public

# n8n API access (for workflow import script)
N8N_BASE_URL=
N8N_API_KEY=

# n8n owner bootstrap
N8N_OWNER_EMAIL=
N8N_OWNER_PASSWORD=
N8N_OWNER_FIRST_NAME=Owner
N8N_OWNER_LAST_NAME=Admin
